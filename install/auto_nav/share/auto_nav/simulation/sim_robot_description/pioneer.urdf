<?xml version="1.0" ?>
<!--
  Pioneer 3-AT URDF for Gazebo Harmonic (gz-sim 8) + ROS 2 Jazzy.

  Design rules:
    - All link/joint names are plain identifiers (no slashes) so ros2 tf2 is happy.
    - Mesh URIs use package://auto_nav/simulation/meshes/ which the launch file
      rewrites to file:// at runtime (avoids needing setup.py data_files).
    - DiffDrive plugin  → publishes /cmd_vel (in), /odom, /tf (out).
    - JointStatePublisher plugin → publishes /joint_states.
-->

<robot name="pioneer3at">

  <!-- ───────────────────────── base ───────────────────────── -->
  <link name="base_link"/>

  <!-- ───────────────────────── chassis ───────────────────────── -->
  <link name="chassis">
    <inertial>
      <mass value="20.0"/>
      <origin xyz="0 0 -0.090"/>
      <inertia ixx="0.3338" ixy="0.0" ixz="0.0"
               iyy="0.4783" iyz="0.0" izz="0.3338"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://auto_nav/simulation/meshes/chassis.dae"/>
      </geometry>
      <material name="ChassisRed">
        <color rgba="0.8 0.0 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://auto_nav/simulation/meshes/chassis.dae"/>
      </geometry>
    </collision>
  </link>
  <gazebo reference="chassis"><material>Gazebo/Red</material></gazebo>

  <joint name="base_chassis_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.00 0 0.177"/>
    <parent link="base_link"/>
    <child  link="chassis"/>
  </joint>

  <!-- ───────────────────────── top plate ───────────────────────── -->
  <link name="top_plate">
    <inertial>
      <mass value="0.1"/>
      <origin xyz="-0.025 0 -0.223"/>
      <inertia ixx="1.0" ixy="0.0" ixz="0.0"
               iyy="1.0" iyz="0.0" izz="1.0"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://auto_nav/simulation/meshes/top.dae"/>
      </geometry>
      <material name="TopBlack">
        <color rgba="0.038 0.038 0.038 1.0"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry><box size="0.1 0.1 0.1"/></geometry>
    </collision>
  </link>
  <gazebo reference="top_plate"><material>Gazebo/Black</material></gazebo>

  <joint name="chassis_top_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.043 0 0.254"/>
    <parent link="base_link"/>
    <child  link="top_plate"/>
  </joint>

  <!-- ═══════════════════════════════════════════════════
       WHEEL ASSEMBLIES  (axle → hub → wheel, per corner)
       Naming: {front|back}_{left|right}_{axle|hub|wheel}
       ═══════════════════════════════════════════════════ -->

  <!-- ── Front-Left ── -->
  <link name="front_left_axle">
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1.0" ixy="0.0" ixz="0.0"
               iyy="1.0" iyz="0.0" izz="1.0"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://auto_nav/simulation/meshes/axle.dae"/>
      </geometry>
      <material name="AxleGrey"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry><box size="0.01 0.01 0.01"/></geometry>
    </collision>
  </link>
  <gazebo reference="front_left_axle"><material>Gazebo/Grey</material></gazebo>

  <joint name="base_front_left_axle_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.135 0.156 0.111"/>
    <parent link="base_link"/>
    <child  link="front_left_axle"/>
  </joint>

  <link name="front_left_hub">
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1.0" ixy="0.0" ixz="0.0"
               iyy="1.0" iyz="0.0" izz="1.0"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://auto_nav/simulation/meshes/left_hubcap.dae"/>
      </geometry>
      <material name="HubcapYellow"><color rgba="1.0 0.811 0.151 1.0"/></material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry><box size="0.01 0.01 0.01"/></geometry>
    </collision>
  </link>
  <gazebo reference="front_left_hub"><material>Gazebo/Yellow</material></gazebo>

  <joint name="base_front_left_hub_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0 0.041 0"/>
    <parent link="front_left_axle"/>
    <child  link="front_left_hub"/>
  </joint>

  <link name="front_left_wheel">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.012411765597" ixy="0" ixz="0"
               iyy="0.015218160428" iyz="0" izz="0.011763977943"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://auto_nav/simulation/meshes/wheel.dae"/>
      </geometry>
      <material name="WheelBlack"><color rgba="0.117 0.117 0.117 1"/></material>
    </visual>
    <collision>
      <origin rpy="-1.57079635 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.075" radius="0.111"/>
      </geometry>
    </collision>
  </link>
  <gazebo reference="front_left_wheel">
    <material>Gazebo/Black</material>
    <kp>1000000.0</kp><kd>1.0</kd><mu1>1.0</mu1><mu2>1.0</mu2>
  </gazebo>

  <joint name="front_left_wheel_joint" type="continuous">
    <axis xyz="0 1 0"/>
    <anchor xyz="0 0 0"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="front_left_hub"/>
    <child  link="front_left_wheel"/>
    <limit effort="100" velocity="100"/>
    <joint_properties damping="0.7"/>
  </joint>

  <!-- ── Front-Right ── -->
  <link name="front_right_axle">
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1.0" ixy="0.0" ixz="0.0"
               iyy="1.0" iyz="0.0" izz="1.0"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://auto_nav/simulation/meshes/axle.dae"/>
      </geometry>
      <material name="AxleGrey"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry><box size="0.01 0.01 0.01"/></geometry>
    </collision>
  </link>
  <gazebo reference="front_right_axle"><material>Gazebo/Grey</material></gazebo>

  <joint name="base_front_right_axle_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.135 -0.156 0.111"/>
    <parent link="base_link"/>
    <child  link="front_right_axle"/>
  </joint>

  <link name="front_right_hub">
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1.0" ixy="0.0" ixz="0.0"
               iyy="1.0" iyz="0.0" izz="1.0"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://auto_nav/simulation/meshes/right_hubcap.dae"/>
      </geometry>
      <material name="HubcapYellow"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry><box size="0.01 0.01 0.01"/></geometry>
    </collision>
  </link>
  <gazebo reference="front_right_hub"><material>Gazebo/Yellow</material></gazebo>

  <joint name="base_front_right_hub_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0 -0.041 0"/>
    <parent link="front_right_axle"/>
    <child  link="front_right_hub"/>
  </joint>

  <link name="front_right_wheel">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.012411765597" ixy="0" ixz="0"
               iyy="0.015218160428" iyz="0" izz="0.011763977943"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://auto_nav/simulation/meshes/wheel.dae"/>
      </geometry>
      <material name="WheelBlack"/>
    </visual>
    <collision>
      <origin rpy="-1.57079635 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.075" radius="0.111"/>
      </geometry>
    </collision>
  </link>
  <gazebo reference="front_right_wheel">
    <material>Gazebo/Black</material>
    <kp>1000000.0</kp><kd>1.0</kd><mu1>1.0</mu1><mu2>1.0</mu2>
  </gazebo>

  <joint name="front_right_wheel_joint" type="continuous">
    <axis xyz="0 1 0"/>
    <anchor xyz="0 0 0"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="front_right_hub"/>
    <child  link="front_right_wheel"/>
    <limit effort="100" velocity="100"/>
    <joint_properties damping="0.7"/>
  </joint>

  <!-- ── Back-Left ── -->
  <link name="back_left_axle">
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1.0" ixy="0.0" ixz="0.0"
               iyy="1.0" iyz="0.0" izz="1.0"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://auto_nav/simulation/meshes/axle.dae"/>
      </geometry>
      <material name="AxleGrey"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry><box size="0.01 0.01 0.01"/></geometry>
    </collision>
  </link>
  <gazebo reference="back_left_axle"><material>Gazebo/Grey</material></gazebo>

  <joint name="base_back_left_axle_joint" type="fixed">
    <origin rpy="0 0 0" xyz="-0.135 0.156 0.111"/>
    <parent link="base_link"/>
    <child  link="back_left_axle"/>
  </joint>

  <link name="back_left_hub">
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1.0" ixy="0.0" ixz="0.0"
               iyy="1.0" iyz="0.0" izz="1.0"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://auto_nav/simulation/meshes/left_hubcap.dae"/>
      </geometry>
      <material name="HubcapYellow"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry><box size="0.01 0.01 0.01"/></geometry>
    </collision>
  </link>
  <gazebo reference="back_left_hub"><material>Gazebo/Yellow</material></gazebo>

  <joint name="base_back_left_hub_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0 0.041 0"/>
    <parent link="back_left_axle"/>
    <child  link="back_left_hub"/>
  </joint>

  <link name="back_left_wheel">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.012411765597" ixy="0" ixz="0"
               iyy="0.015218160428" iyz="0" izz="0.011763977943"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://auto_nav/simulation/meshes/wheel.dae"/>
      </geometry>
      <material name="WheelBlack"/>
    </visual>
    <collision>
      <origin rpy="-1.57079635 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.075" radius="0.111"/>
      </geometry>
    </collision>
  </link>
  <gazebo reference="back_left_wheel">
    <material>Gazebo/Black</material>
    <kp>1000000.0</kp><kd>1.0</kd><mu1>1.0</mu1><mu2>1.0</mu2>
  </gazebo>

  <joint name="back_left_wheel_joint" type="continuous">
    <axis xyz="0 1 0"/>
    <anchor xyz="0 0 0"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="back_left_hub"/>
    <child  link="back_left_wheel"/>
    <limit effort="100" velocity="100"/>
    <joint_properties damping="0.7"/>
  </joint>

  <!-- ── Back-Right ── -->
  <link name="back_right_axle">
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1.0" ixy="0.0" ixz="0.0"
               iyy="1.0" iyz="0.0" izz="1.0"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://auto_nav/simulation/meshes/axle.dae"/>
      </geometry>
      <material name="AxleGrey"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry><box size="0.01 0.01 0.01"/></geometry>
    </collision>
  </link>
  <gazebo reference="back_right_axle"><material>Gazebo/Grey</material></gazebo>

  <joint name="base_back_right_axle_joint" type="fixed">
    <origin rpy="0 0 0" xyz="-0.135 -0.156 0.111"/>
    <parent link="base_link"/>
    <child  link="back_right_axle"/>
  </joint>

  <link name="back_right_hub">
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1.0" ixy="0.0" ixz="0.0"
               iyy="1.0" iyz="0.0" izz="1.0"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://auto_nav/simulation/meshes/right_hubcap.dae"/>
      </geometry>
      <material name="HubcapYellow"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry><box size="0.01 0.01 0.01"/></geometry>
    </collision>
  </link>
  <gazebo reference="back_right_hub"><material>Gazebo/Yellow</material></gazebo>

  <joint name="base_back_right_hub_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0 -0.041 0"/>
    <parent link="back_right_axle"/>
    <child  link="back_right_hub"/>
  </joint>

  <link name="back_right_wheel">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.012411765597" ixy="0" ixz="0"
               iyy="0.015218160428" iyz="0" izz="0.011763977943"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://auto_nav/simulation/meshes/wheel.dae"/>
      </geometry>
      <material name="WheelBlack"/>
    </visual>
    <collision>
      <origin rpy="-1.57079635 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.075" radius="0.111"/>
      </geometry>
    </collision>
  </link>
  <gazebo reference="back_right_wheel">
    <material>Gazebo/Black</material>
    <kp>1000000.0</kp><kd>1.0</kd><mu1>1.0</mu1><mu2>1.0</mu2>
  </gazebo>

  <joint name="back_right_wheel_joint" type="continuous">
    <axis xyz="0 1 0"/>
    <anchor xyz="0 0 0"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="back_right_hub"/>
    <child  link="back_right_wheel"/>
    <limit effort="100" velocity="100"/>
    <joint_properties damping="0.7"/>
  </joint>

  <!-- ═══════════════════════════════════════════════════
       GAZEBO PLUGINS  (Gazebo Harmonic / gz-sim 8)
       ═══════════════════════════════════════════════════ -->

  <!--
    DiffDrive:
      • Subscribes GZ topic /cmd_vel  (Twist)
      • Publishes  GZ topic /odom     (Odometry)  @ 20 Hz
      • Publishes  GZ topic /tf       (Pose_V)    → odom→base_link
  -->
  <gazebo>
    <plugin filename="gz-sim-diff-drive-system"
            name="gz::sim::systems::DiffDrive">
      <left_joint>front_left_wheel_joint</left_joint>
      <left_joint>back_left_wheel_joint</left_joint>
      <right_joint>front_right_wheel_joint</right_joint>
      <right_joint>back_right_wheel_joint</right_joint>
      <wheel_separation>0.394</wheel_separation>
      <wheel_radius>0.111</wheel_radius>
      <odom_publish_frequency>20</odom_publish_frequency>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
      <tf_topic>/tf</tf_topic>
    </plugin>

    <!-- Publishes /joint_states so robot_state_publisher can update wheel TF -->
    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
      <topic>joint_states</topic>
    </plugin>
  </gazebo>

  <!-- ═══════════════════════════════════════════════════
       IMU  (kept for later fusion; not bridged in G1)
       ═══════════════════════════════════════════════════ -->
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="imu_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="imu_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.03 0.02 0.01"/></geometry>
      <material name="imuOrange"><color rgba="1.0 0.4 0.0 1.0"/></material>
    </visual>
  </link>

  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <visualize>false</visualize>
      <topic>imu</topic>
      <gz_frame_id>imu_link</gz_frame_id>
      <imu>
        <angular_velocity>
          <x><noise type="gaussian"><mean>0</mean><stddev>0.0002</stddev></noise></x>
          <y><noise type="gaussian"><mean>0</mean><stddev>0.0002</stddev></noise></y>
          <z><noise type="gaussian"><mean>0</mean><stddev>0.0002</stddev></noise></z>
        </angular_velocity>
        <linear_acceleration>
          <x><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></x>
          <y><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></y>
          <z><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></z>
        </linear_acceleration>
      </imu>
    </sensor>
  </gazebo>

  <!-- ═══════════════════════════════════════════════════
       LIDAR  (not bridged in G1, included for completeness)
       ═══════════════════════════════════════════════════ -->
  <joint name="laser_joint" type="fixed">
    <parent link="chassis"/>
    <child  link="laser_frame"/>
    <origin xyz="0.2 0 0.104" rpy="0 0 0"/>
  </joint>

  <link name="laser_frame">
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.01 0.01 0.01"/></geometry>
    </collision>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://auto_nav/simulation/meshes/hokuyo1.dae"/>
      </geometry>
    </visual>
    <inertial>
      <mass value="1e-5"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>

  <gazebo reference="laser_frame">
    <material>Gazebo/Blue</material>
    <!--
      type="lidar"  — CPU raycasting, no Ogre2/GPU required.
      gpu_lidar requires <render_engine>ogre2</render_engine> which hangs Gazebo
      on VMs without proper EGL/DRI support.
    -->
    <sensor name="laser" type="lidar">
      <topic>scan</topic>
      <update_rate>10</update_rate>
      <gz_frame_id>laser_frame</gz_frame_id>
      <lidar>
        <scan>
          <horizontal>
            <samples>720</samples>
            <resolution>1</resolution>
            <min_angle>-2.0944</min_angle>
            <max_angle>2.0944</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.35</min>
          <max>12.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.015</stddev>
        </noise>
      </lidar>
      <always_on>1</always_on>
      <visualize>true</visualize>
    </sensor>
  </gazebo>

  <!-- ═══════════════════════════════════════════════════
       CAMERA  (not bridged in G1, included for completeness)
       ═══════════════════════════════════════════════════ -->
  <joint name="cam_joint" type="fixed">
    <parent link="chassis"/>
    <child  link="cam_frame"/>
    <origin xyz="0.24 0 0.084" rpy="0 0 0"/>
  </joint>

  <link name="cam_frame">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.01 0.05 0.01"/></geometry>
      <material name="greenCam"><color rgba="0 1.0 0 1.0"/></material>
    </visual>
  </link>

  <joint name="cam_optical_joint" type="fixed">
    <parent link="cam_frame"/>
    <child  link="cam_optical_link"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
  </joint>

  <link name="cam_optical_link"/>

  <gazebo reference="cam_frame">
    <sensor name="camera" type="camera">
      <pose>0 0 0 0 0 0</pose>
      <always_on>true</always_on>
      <update_rate>20</update_rate>
      <visualize>false</visualize>
      <topic>camera</topic>
      <gz_frame_id>cam_optical_link</gz_frame_id>
      <camera>
        <horizontal_fov>1.089</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <noise><type>gaussian</type><mean>0.0</mean><stddev>2.5</stddev></noise>
        <clip><near>0.1</near><far>15.0</far></clip>
      </camera>
    </sensor>
  </gazebo>

</robot>
